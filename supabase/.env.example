# Edge Function Environment Variables
# Copy this to .env and fill in your real values.
# NEVER commit .env to version control.

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── OpenAI ───────────────────────────────────────────────────
# Used by the ai-orchestrator Edge Function for embeddings & chat completions
OPENAI_API_KEY=sk-...

# ── Local Dev ────────────────────────────────────────────────
# These are auto-set by `supabase start`; only needed for manual scripts
LOCAL_SUPABASE_URL=http://localhost:54321
LOCAL_SERVICE_ROLE_KEY=local-service-role-key
