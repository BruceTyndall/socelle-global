# ── Socelle — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control — it's in .gitignore.

# ── Supabase (required) ────────────────────────────────────────────
VITE_SUPABASE_URL=https://rumdmulxzmjtsplsjngi.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── App config (optional) ─────────────────────────────────────────
# VITE_APP_URL=https://socelle.com
VITE_SUPPORT_EMAIL=debvaihello@gmail.com

# Set to true to run the app without Supabase (UI only; data/auth will not work)
# VITE_SUPABASE_BYPASS=true

# ── AI keys (DO NOT add here — expose server-side only) ───────────
# Claude:  supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# Gemini:  supabase secrets set GOOGLE_GEMINI_API_KEY=...
# These must NOT be in the browser bundle. Set them as Supabase secrets.

# ── Stripe (set when Stripe is wired up) ──────────────────────────
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Stripe secret key → NEVER expose in frontend, set in Supabase secrets only

# ── Feature flags (optional) ─────────────────────────────────────
# VITE_ENABLE_ANALYTICS=false
